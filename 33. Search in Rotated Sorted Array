class Solution {
public:
    int search(vector<int>& arr, int target) {
        int n=arr.size();
        int low=0;
        int high=n-1;
        int res=0;

        // minimum element ka index find karenge
        while(low<=high){
            if(arr[low]<=arr[high]){
                res=low;
                break;
            }

            int mid=low+(high-low)/2;
            int prev=(mid+n-1)%n;
            int next=(mid+1)%n;

            if(arr[mid]<=arr[prev] && arr[mid]<=arr[next]){
                res=mid;
                break;
            }
            else if(arr[low]<=arr[mid]){
                low=mid+1;
            }
            else{
                high=mid-1;
            }
        }

        int ans=-1;

        // first part me binary search
        low=0;
        high=res-1;
        while(low<=high){
            int mid=low+(high-low)/2;
            if(arr[mid]==target){
                ans=mid;
                break;
            }
            else if(arr[mid]<target){
                low=mid+1;
            }
            else{
                high=mid-1;
            }
        }

        // agar first part me nahi mila toh second part me search karo
        if(ans==-1){
            low=res;
            high=n-1;
            while(low<=high){
                int mid=low+(high-low)/2;
                if(arr[mid]==target){
                    ans=mid;
                    break;
                }
                else if(arr[mid]<target){
                    low=mid+1;
                }
                else{
                    high=mid-1;
                }
            }
        }

        return ans;
    }
};
