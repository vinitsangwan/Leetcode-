class Solution {
public:
    bool isPalindrome(int x) {
        long long reverse=0;
        int original=x;
        while(x>0){
            int last_digit=x%10;
            if(reverse>INT_MAX/10 || reverse<INT_MIN/10)
            return false;

            reverse=reverse*10+last_digit;
            x=x/10;
        }
        if(x<0){
            return false;
        }
        else if(reverse==original){
            return true;
        }
        else{
            return false;
        }
     


    }
};
