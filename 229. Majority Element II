class Solution {
public:
    vector<int> majorityElement(vector<int>& nums) {
      map<int,int>mp;
      for(int i=0;i<nums.size();i++){
        mp[nums[i]]++;
      }
      set<int>s;
      vector<int>ans;
      for(int i=0;i<nums.size();i++){
        if(mp[nums[i]]>nums.size()/3){
            s.insert(nums[i]);
        }
      }
      for(auto it:s){
        ans.push_back(it);
      }
      return ans;
      


    }
};
